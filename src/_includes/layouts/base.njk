<!DOCTYPE html>
<html lang="{{ site.languageCode | default("en-us") }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if page.url == "/" %}{{ site.title }}{% else %}{{ title }} | {{ site.title }}{% endif %}</title>
  
  <!-- SEO Metadata -->
  <meta name="description" content="{{ description | default(site.description) }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  
  <!-- Stylesheet -->
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>

  <!-- Header Section -->
  <header class="site-header">
    <div class="nav-container">
      <a href="/" class="brand">
        {% if site.logo %}
          <img src="{{ site.logo }}" alt="{{ site.title }} logo">
        {% endif %}
        <span class="brand-name">{{ site.title }}</span>
      </a>
      
      <nav aria-label="Main Navigation">
        <ul class="nav-links">
          {% for item in site.menu %}
            <li>
              <a href="{{ item.url }}" 
                 class="{% if page.url == item.url or (item.url != '/' and page.url.startsWith(item.url)) %}active{% endif %}"
                 title="{{ item.name }}">
                {{ item.name }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    </div>
  </header>

  <!-- Main Content Block -->
  <main id="main-content">
    {{ content | safe }}
  </main>

  <!-- Footer Section -->
  <footer>
    <div class="footer-container">
      <div class="footer-about">
        <h4>{{ site.title }}</h4>
        <p>{{ site.description }}</p>
      </div>
      <div class="footer-links">
        <h5>Explore</h5>
        <ul>
          {% for item in site.menu %}
            <li><a href="{{ item.url }}">{{ item.name }}</a></li>
          {% endfor %}
        </ul>
      </div>
      <div class="footer-social">
        <h5>Contact & Social</h5>
        <p style="font-size: 0.95rem; margin-bottom: 0.75rem;">{{ site.address }}</p>
        <p style="font-size: 0.95rem; margin-bottom: 0.75rem;"><a href="mailto:{{ site.email }}">{{ site.email }}</a></p>
        {% if site.instagram %}
          <p style="font-size: 0.95rem; margin-bottom: 0.5rem;"><a href="{{ site.instagram }}" target="_blank" rel="noopener">Instagram</a></p>
        {% endif %}
        {% if site.bluesky %}
          <p style="font-size: 0.95rem; margin-bottom: 0.5rem;"><a href="{{ site.bluesky }}" target="_blank" rel="noopener">Bluesky</a></p>
        {% endif %}
        {% if site.kofi %}
          <p style="font-size: 0.95rem; margin-bottom: 0.5rem;"><a href="{{ site.kofi }}" target="_blank" rel="noopener">Ko-fi Shop</a></p>
        {% endif %}
      </div>
    </div>
    <div class="footer-bottom">
      <div>&copy; {% currentYear %} {{ site.copyright }}. All rights reserved.</div>
      <div>Website by Antigravity</div>
    </div>
  </footer>

  <!-- Global Lightbox Modal -->
  <dialog id="global-lightbox" class="lightbox">
    <div class="lightbox-content">
      <button class="close-lightbox" aria-label="Close lightbox">&times;</button>
      <div class="lightbox-image-container">
        <img src="" alt="Enlarged view">
      </div>
      <div class="lightbox-info">
        <h3 class="lightbox-title">Image Title</h3>
        <div class="lightbox-details">
          <span><strong style="color: var(--accent);">Specs:</strong> <span class="lightbox-camera">Camera Info</span></span>
          <span style="border-left: 1px solid var(--border-color); padding-left: 1.5rem;"><strong style="color: var(--accent);">Edition:</strong> <span class="lightbox-edition">Edition Info</span></span>
        </div>
      </div>
    </div>
  </dialog>

  <!-- Lightbox Script (Used in Gallery and Portfolio pages) -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const lightbox = document.getElementById('global-lightbox');
      if (!lightbox) return;

      const lightboxImg = lightbox.querySelector('.lightbox-image-container img');
      const lightboxTitle = lightbox.querySelector('.lightbox-title');
      const lightboxCamera = lightbox.querySelector('.lightbox-camera');
      const lightboxEdition = lightbox.querySelector('.lightbox-edition');
      const closeBtn = lightbox.querySelector('.close-lightbox');

      // Add click handler to all lightbox trigger images
      document.querySelectorAll('[data-lightbox-src]').forEach(img => {
        img.addEventListener('click', () => {
          const src = img.getAttribute('data-lightbox-src');
          const title = img.getAttribute('data-lightbox-title') || '';
          const camera = img.getAttribute('data-lightbox-camera') || '';
          const edition = img.getAttribute('data-lightbox-edition') || '';

          if (lightboxImg) lightboxImg.src = src;
          if (lightboxTitle) lightboxTitle.textContent = title;
          
          if (lightboxCamera) {
            if (camera) {
              lightboxCamera.textContent = camera;
              lightboxCamera.parentElement.style.display = 'inline-flex';
            } else {
              lightboxCamera.parentElement.style.display = 'none';
            }
          }
          
          if (lightboxEdition) {
            if (edition) {
              lightboxEdition.textContent = edition;
              lightboxEdition.parentElement.style.display = 'inline-flex';
            } else {
              lightboxEdition.parentElement.style.display = 'none';
            }
          }

          lightbox.showModal();
        });
      });

      // Close button handler
      if (closeBtn) {
        closeBtn.addEventListener('click', () => {
          lightbox.close();
        });
      }

      // Close when clicking backdrop
      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox) {
          lightbox.close();
        }
      });
      
      // Clear image source on close to prevent visual glitch next open
      lightbox.addEventListener('close', () => {
        if (lightboxImg) lightboxImg.src = '';
      });
    });
  </script>

</body>
</html>

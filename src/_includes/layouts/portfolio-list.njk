---
layout: layouts/base.njk
---
<div style="max-width: var(--max-width); margin: 0 auto;">
  <header style="margin-bottom: 4rem; text-align: center;">
    <h1 style="text-transform: uppercase; letter-spacing: 0.05em; font-family: var(--font-serif);">{{ title }}</h1>
    <p class="hero-subtitle" style="font-size: 1.2rem; margin-top: 1rem; color: var(--accent); font-style: italic;">
      {{ subtitle | default("Limited Edition Archival Pigment Prints") }}
    </p>
    <p style="max-width: 600px; margin: 1.5rem auto 0; color: var(--text-secondary); font-size: 1rem;">
      All works are printed on museum-grade cotton rag papers (Hahnemühle) using archival mineral pigments. Each print is numbered, signed, and accompanied by a Certificate of Authenticity.
    </p>
  </header>

  <div class="grid-container" style="margin-top: 3rem;">
    {% for item in collections.portfolio %}
      <div class="grid-item">
        <div class="grid-image-wrapper">
          <a href="{{ item.url }}">
            <img src="{{ item.data.image }}" alt="{{ item.data.title }}">
          </a>
        </div>
        <div class="grid-info">
          <span class="badge">{{ item.data.edition_type | default("Limited Edition") }}</span>
          <h3 style="margin-bottom: 0.5rem;"><a href="{{ item.url }}">{{ item.data.title }}</a></h3>
          <p style="font-size: 0.95rem; line-height: 1.4; margin-bottom: 1.5rem; flex-grow: 1;">{{ item.data.description }}</p>
          <div class="grid-meta">
            <span>{{ item.data.dimensions }}</span>
            <span style="color: var(--accent); font-weight: 600;">{{ item.data.price }}</span>
          </div>
        </div>
      </div>
    {% else %}
      <p style="grid-column: 1/-1; text-align: center; color: var(--text-muted); padding: 3rem;">No fine art prints are currently in the portfolio.</p>
    {% endfor %}
  </div>
</div>

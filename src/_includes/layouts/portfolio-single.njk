---
layout: layouts/base.njk
---
<div class="print-detail-container" style="max-width: var(--max-width); margin: 0 auto;">
  
  <!-- Left Side: Large Visual Showcase -->
  <div class="print-gallery">
    {% if image %}
      <img src="{{ image }}" alt="{{ title }}" class="print-main-img" 
           data-lightbox-src="{{ image }}" 
           data-lightbox-title="{{ title }}"
           data-lightbox-camera="{{ camera }}"
           data-lightbox-edition="Limited Edition of {{ edition_size }}"
           style="cursor: zoom-in;">
      <p style="text-align: center; color: var(--text-muted); font-size: 0.85rem; margin-top: 1rem; font-style: italic;">
        Click image to view in full resolution
      </p>
    {% else %}
      <div style="background: var(--bg-tertiary); display: flex; justify-content: center; align-items: center; aspect-ratio: 1/1; border-radius: 4px; border: 1px solid var(--border-color); width: 100%; min-height: 350px;">
        <span style="color: var(--text-muted); font-size: 3rem; font-family: var(--font-serif);">Ars</span>
      </div>
    {% endif %}
  </div>

  <!-- Right Side: Details and Print Inquiry -->
  <div class="print-meta-box">
    <span class="badge" style="margin-bottom: 0.5rem;">{{ edition_type | default("Limited Edition") }}</span>
    <h1 class="print-title" style="font-family: var(--font-serif); font-size: 2.5rem; font-weight: 300;">{{ title }}</h1>
    <p class="print-tagline">{{ series }} Series ({{ year }})</p>
    
    <div style="color: var(--text-secondary); margin-bottom: 2rem; line-height: 1.7;">
      {{ content | safe }}
    </div>

    <h3 style="font-size: 1.1rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--accent); margin-bottom: 1rem; font-family: var(--font-sans); font-weight: 600;">
      Print Specifications
    </h3>
    
    <ul class="print-specs-list">
      <li>
        <span>Paper Medium</span>
        <span>{{ paper | default("Hahnemühle Photo Rag 308gsm (100% Cotton)") }}</span>
      </li>
      <li>
        <span>Print Method</span>
        <span>{{ print_method | default("Archival Pigment Inkjet (Giclée)") }}</span>
      </li>
      <li>
        <span>Image Size</span>
        <span>{{ dimensions }}</span>
      </li>
      <li>
        <span>Edition Size</span>
        <span>Limited to {{ edition_size | default("15") }} impressions</span>
      </li>
      <li>
        <span>Signatures</span>
        <span>Numbered & signed on front / reverse</span>
      </li>
      <li>
        <span>Framing</span>
        <span>{{ framing | default("Unframed (Available on request)") }}</span>
      </li>
    </ul>

    <div class="print-price">
      {{ price }}
      <span style="font-size: 0.85rem; color: var(--text-muted); display: block; font-family: var(--font-sans); font-weight: normal; margin-top: 0.25rem;">
        Excl. shipping. Includes Certificate of Authenticity.
      </span>
    </div>

    <!-- Inquiry Link with Query Parameter -->
    <a href="/contact/?print={{ title | urlencode }}" class="btn btn-primary">
      Inquire About This Print
    </a>
  </div>
  
</div>

<div style="margin-top: 5rem; text-align: center; border-top: 1px solid var(--border-color); padding-top: 3rem;">
  <a href="/portfolio/" class="btn btn-outline" style="max-width: 300px;">&larr; Back to Portfolio</a>
</div>

---
layout: layouts/base.njk
---
<article class="single-page-content">
  <header>
    <h1 style="font-family: var(--font-serif); font-weight: 300;">{{ title }}</h1>
    
    {% if page.url and page.url.startsWith("/blog/") %}
      <div class="post-meta">
        <span>Published on {{ date | postDate }}</span>
        {% if author %}
          <span style="margin-left: 1.5rem;">By {{ author }}</span>
        {% endif %}
      </div>
    {% else %}
      <div style="height: 2px; background: var(--border-light); margin: 1.5rem 0 3rem 0;"></div>
    {% endif %}
  </header>

  {% if image %}
    <div style="margin-bottom: 3rem; width: 100%; border: 1px solid var(--border-color); border-radius: 4px; overflow: hidden; aspect-ratio: 16/9;">
      <img src="{{ image }}" alt="{{ title }}" style="width: 100%; height: 100%; object-fit: cover;">
    </div>
  {% endif %}

  <div class="post-body">
    {{ content | safe }}
  </div>
</article>
